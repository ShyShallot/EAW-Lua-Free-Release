<?xml version="1.0"?>

<Story>

    <Event Name="Init_GC">
        <Event_Type>STORY_ELAPSED</Event_Type>
        <Event_Param1>0</Event_Param1>
    </Event>

    <Event Name="Universal_Story_Start">
        <Event_Type>STORY_AI_NOTIFICATION</Event_Type>
        <Event_Param2>Spawning_Done</Event_Param2>
        <Story_Dialog>DIALOG_FILE</Story_Dialog>
        <Story_Chapter>1</Story_Chapter>
        <Story_Tag>Intro_Tag</Story_Tag>
    </Event>

    <Event Name="Show_Screen_Text">
		<Event_Type>STORY_AI_NOTIFICATION</Event_Type>
		<Event_Param2>SHOW_SCREEN_TEXT</Event_Param2>
		<Reward_Type>SCREEN_TEXT</Reward_Type>
		<Reward_Param1></Reward_Param1>
		<Reward_Param2>-1</Reward_Param2>
		<Perpetual>true</Perpetual>
	</Event>

</Story>